generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PROVIDER
  CLIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role     @default(CLIENT)
  createdAt    DateTime @default(now()) @map("created_at")

  services     Service[]
  timeSlots    TimeSlot[]
  appointments Appointment[] @relation("ClientAppointments")

  @@map("users")
}

model Service {
  id            String    @id @default(uuid())
  name          String    
  description   String?
  price         Float
  duration      Int       //minutes
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relation : A service belongs to a provider (user)
  providerId    String    @map("provider_id")
  provider      User      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@map("services")
}

model TimeSlot {
  id              String    @id @default(uuid())
  startTime       DateTime  @map("start_time")
  endTime         DateTime  @map("end_time")
  isAvailable     Boolean   @default(true)  @map("is_avalible")
  createdAt       DateTime  @default(now()) @map("created_at")

  providerId      String    @map("provider_id")
  provider        User      @relation(fields: [providerId], references: [id], onDelete: Cascade)

  appointments Appointment[]

  @@map("time_slots")
}

model Appointment {
  id                String              @id @default(uuid())
  appointmentTime   DateTime            @map("appointment_time")
  status            AppointmentStatus   @default(PENDING)
  notes             String?     
  createdAt         DateTime            @default(now()) @map("created_At")
  updatedAt         DateTime            @updatedAt @map("updated_at")       

  clientId          String              @map("client_id")
  client            User                @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  
  serviceId         String              @map("service_id")
  service           Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  timeSlotId        String              @map("time_slot_id")
  timeSlot          TimeSlot            @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  @@map("appointments")
}